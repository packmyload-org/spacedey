{
  "name": "spacedey",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typeorm": "tsx --tsconfig tsconfig.json ./node_modules/typeorm/cli.js -d scripts/typeorm-data-source.ts",
    "db:migrate": "pnpm typeorm migration:run",
    "db:migrate:revert": "pnpm typeorm migration:revert",
    "db:migrate:show": "pnpm typeorm migration:show",
    "db:baseline": "tsx --tsconfig tsconfig.json scripts/baseline-migrations.ts",
    "db:setup": "pnpm db:migrate && pnpm run seed:data",
    "seed:data": "tsx --tsconfig tsconfig.json scripts/seed-db-typeorm.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@vercel/analytics": "^2.0.0",
    "@vis.gl/react-google-maps": "^1.7.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.29.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.544.0",
    "next": "^16.1.5",
    "pg": "^8.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.28",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/axios": "^0.14.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
