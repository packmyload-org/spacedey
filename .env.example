# Supabase (Data API — use pooler URL for POSTGRES_URL in production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres pooler (multi-statement transactions via lib/db/transaction.ts)
POSTGRES_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_POSTGRES_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DB_USE_DIRECT_URL=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Auth and security
JWT_SECRET=your-secure-secret-key
PASSWORD_SALT=your-salt-value
TOKEN_SECRET=your-token-secret

# Optional integrations
NEXT_PUBLIC_MAPS_ENABLED=true
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
ENABLE_VERCEL_INSIGHTS=false
RESEND_API_KEY=
RESEND_FROM_EMAIL="Spacedey <onboarding@resend.dev>"
RESEND_WEBHOOK_SECRET=
SUPPORT_EMAIL=info@mailing.spacedey.com
SUPPORT_PHONE=09166680777
SUPPORT_HOURS="Monday to Friday, 9am to 6pm"
ALERT_NOTIFICATION_EMAILS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PREFIX=spacedey

PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# App
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
