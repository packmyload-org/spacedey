# Database configuration
# Preferred for Supabase / Vercel
DATABASE_URL=postgresql://...
DIRECT_DATABASE_URL=postgresql://...
DB_USE_DIRECT_URL=false
DB_TYPE=postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Optional fallback for local or host-based Postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=spacedey

# Auth and security
JWT_SECRET=your-secure-secret-key
PASSWORD_SALT=your-salt-value
TOKEN_SECRET=your-token-secret

# Optional integrations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_ENABLE_GOOGLE_MAPS=false
NEXT_PUBLIC_GOOGLE_MAPS_BILLING_ENABLED=false
# NEXT_PUBLIC_ZENDESK_KEY=
# PAYSTACK_SECRET_KEY=
# FLUTTERWAVE_SECRET_KEY=
# GCP_PROJECT_ID=
# GCP_SERVICE_ACCOUNT_KEY=
# GCP_STORAGE_BUCKET=spacedey-uploads

# App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
