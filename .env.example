# Database configuration
DATABASE_URL=postgresql://...
DIRECT_DATABASE_URL=postgresql://...
DB_USE_DIRECT_URL=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Auth and security
JWT_SECRET=your-secure-secret-key
PASSWORD_SALT=your-salt-value
TOKEN_SECRET=your-token-secret

# Optional integrations
NEXT_PUBLIC_MAPS_ENABLED=true
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
ENABLE_VERCEL_INSIGHTS=false
RESEND_API_KEY=
RESEND_FROM_EMAIL="Spacedey <onboarding@resend.dev>"
RESEND_WEBHOOK_SECRET=
SUPPORT_EMAIL=info@mailing.spacedey.com
SUPPORT_PHONE=09166680777
SUPPORT_HOURS="Monday to Friday, 9am to 6pm"
ALERT_NOTIFICATION_EMAILS=
# Paste your Cloudinary credentials here for admin uploads and editable media fields.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PREFIX=spacedey

PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_SECRET_HASH=

# App
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
