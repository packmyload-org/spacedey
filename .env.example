# Database configuration
DATABASE_URL=postgresql://...
DIRECT_DATABASE_URL=postgresql://...
DB_USE_DIRECT_URL=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Auth and security
JWT_SECRET=your-secure-secret-key
PASSWORD_SALT=your-salt-value
TOKEN_SECRET=your-token-secret

# Optional integrations
NEXT_PUBLIC_MAPS_ENABLED=true
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
# NEXT_PUBLIC_ZENDESK_KEY=
# PAYSTACK_SECRET_KEY=
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_SECRET_HASH=
# GCP_PROJECT_ID=
# GCP_SERVICE_ACCOUNT_KEY=
# GCP_STORAGE_BUCKET=spacedey-uploads

# App
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000
